{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "EPUB Reader",
  "version": "0.2.0",
  "identifier": "com.epub-reader.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "EPUB Reader",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' blob: data: https://fonts.googleapis.com; font-src 'self' blob: data: https://fonts.gstatic.com asset:; img-src 'self' data: asset: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' asset: data: blob:; media-src 'self' asset: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}